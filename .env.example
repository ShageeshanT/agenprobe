# OpenClaw bot — public URL of the gateway (Railway wrapper auto-adds auth)
OPENCLAW_GATEWAY_URL=https://openclaw-main-production-1170.up.railway.app
OPENCLAW_AGENT_ID=main

# Optional: if you want to bypass the wrapper and hit the gateway directly,
# set these instead (and leave OPENCLAW_GATEWAY_URL unset).
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-token-here
