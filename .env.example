# OpenClaw bot — public URL of the gateway (Railway wrapper auto-adds auth)
OPENCLAW_GATEWAY_URL=https://openclaw-main-production-1170.up.railway.app
OPENCLAW_AGENT_ID=main

# Optional: if you want to bypass the wrapper and hit the gateway directly,
# set these instead (and leave OPENCLAW_GATEWAY_URL unset).
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-token-here

# Hermes bot — reached via `railway ssh`, not HTTP. Coordinates come from
# the Railway dashboard / the `railway ssh --project=... --environment=...
# --service=...` command. The adapter shells out to `hermes chat -q ... -Q
# --source tool --yolo` on every sendMessage call.
HERMES_RAILWAY_PROJECT=773b5a75-3dd1-45c7-b751-89eabe59ff81
HERMES_RAILWAY_ENVIRONMENT=de9b2b58-040e-4c50-bcff-6fdc89efc0ec
HERMES_RAILWAY_SERVICE=be5247d6-5956-43cc-b020-5a031320ba97
